{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "next-start",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "start", "-p", "4000"],
      "port": 4000
    },
    {
      "name": "docker-dev",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "dev"],
      "port": 3001
    },
    {
      "name": "docker-app",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "app"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
